# ============================================================================
#  Việt Anh Media Hub — mẫu .env cho DEPLOY PRODUCTION (Docker VPS / Coolify)
#  Copy file này thành .env rồi điền giá trị thật:  cp .env.production.example .env
#  docker-compose.prod.yaml đọc file .env này (env_file + ${} substitution).
#
#  CHỈ CÒN HẠ TẦNG Ở ĐÂY. Mọi API key (Claude, OpenAI/Fal, OAuth mạng xã hội,
#  Zalo OA, YouTube/Apify, token Trang Facebook của bot…) nhập QUA UI sau khi
#  đăng nhập — được lưu vào volume /config (CONFIG_DIR) và /app/data (bot) nên
#  SỐNG QUA restart/rebuild container.
#    · Hub:   Settings → Claude AI / Tạo ảnh / Social keys
#    · Bot:   trang Zalo → tab Token Facebook / Google Business / Cài đặt
# ============================================================================

# --- BẮT BUỘC ---------------------------------------------------------------
# Domain công khai (đằng sau reverse proxy HTTPS). KHÔNG có dấu / ở cuối.
FRONTEND_URL=https://hub.truongvietanh.com

# Chuỗi ngẫu nhiên DÀI, giữ bí mật (đổi = đăng xuất tất cả). Tạo:
#   openssl rand -hex 32
JWT_SECRET=thay-bang-chuoi-ngau-nhien-that-dai

# Mật khẩu Postgres (compose dùng cho cả DB lẫn DATABASE_URL). Đặt mạnh.
POSTGRES_PASSWORD=thay-bang-mat-khau-manh

# Cổng host map ra container nginx:5000 (reverse proxy trỏ vào cổng này).
PORT=4007

# Chỉ admin tạo/mời tài khoản (không mở đăng ký công khai). Để 'true'.
DISABLE_REGISTRATION=true
# NOT_SECURED=false  # để mặc định; chỉ bật khi chạy HTTP thuần (không khuyến nghị)

# --- Bot Zalo (service zalo-bot trong compose) -------------------------------
# Bí mật chung để Hub gọi API bot qua /botapi. Tạo:  openssl rand -hex 24
# (Nếu bot chạy bằng app Coolify riêng: set CÙNG giá trị này + WEB_HOST=0.0.0.0
#  cho app đó, và đặt ZALO_BOT_URL bên dưới trỏ tới địa chỉ nội bộ của app.)
HUB_BOT_TOKEN=thay-bang-chuoi-ngau-nhien
# Mật khẩu dashboard riêng của bot (bot từ chối chạy nếu yếu — ≥8 ký tự).
# Bình thường KHÔNG cần mở dashboard này nữa (trang Zalo trong Hub thay thế).
ZALO_DASHBOARD_PASS=thay-bang-mat-khau-manh
# ZALO_DASHBOARD_USER=admin

# Địa chỉ nội bộ của bot — mặc định service zalo-bot trong cùng compose.
# ZALO_BOT_URL=http://zalo-bot:8088
