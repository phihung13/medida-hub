# ============================================================================
#  Việt Anh Media Hub — mẫu .env cho DEPLOY PRODUCTION (Docker VPS)
#  Copy file này thành .env rồi điền giá trị thật:  cp .env.production.example .env
#  docker-compose.prod.yaml đọc file .env này (env_file + ${} substitution).
#  Hạ tầng nội bộ (DATABASE_URL, REDIS_URL, TEMPORAL_ADDRESS) đã cố định trong
#  compose — KHÔNG cần khai ở đây.
# ============================================================================

# --- BẮT BUỘC ---------------------------------------------------------------
# Domain công khai (đằng sau reverse proxy HTTPS). KHÔNG có dấu / ở cuối.
FRONTEND_URL=https://hub.truongvietanh.com

# Chuỗi ngẫu nhiên DÀI, giữ bí mật (đổi = đăng xuất tất cả). Tạo:
#   openssl rand -hex 32
JWT_SECRET=thay-bang-chuoi-ngau-nhien-that-dai

# Mật khẩu Postgres (compose dùng cho cả DB lẫn DATABASE_URL). Đặt mạnh.
POSTGRES_PASSWORD=thay-bang-mat-khau-manh

# Cổng host map ra container nginx:5000 (reverse proxy trỏ vào cổng này).
PORT=4007

# Chỉ admin tạo/mời tài khoản (không mở đăng ký công khai). Để 'true'.
DISABLE_REGISTRATION=true
# NOT_SECURED=false  # để mặc định; chỉ bật khi chạy HTTP thuần (không khuyến nghị)

# --- AI (Media Hub chạy Claude) --------------------------------------------
# Đặt key ở ĐÂY (bền qua restart). ĐỪNG dựa vào ô nhập-key trên UI cho
# production — file key runtime nằm trong container sẽ mất khi rebuild.
ANTHROPIC_API_KEY=sk-ant-...
# Tạo ảnh (Claude không tạo ảnh) — chọn 1 nếu dùng: OpenAI hoặc Fal
OPENAI_API_KEY=

# --- Zalo OA (kênh đăng ngược ra Zalo) -------------------------------------
ZALO_APP_ID=
ZALO_APP_SECRET=

# --- Discover / Lò Bài Thắng (tuỳ chọn) ------------------------------------
YOUTUBE_API_KEY=
APIFY_TOKEN=

# --- OAuth mạng xã hội (điền khi kết nối kênh; có thể nhập qua UI Settings) --
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GOOGLE_GMB_CLIENT_ID=
GOOGLE_GMB_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TELEGRAM_BOT_NAME=
TELEGRAM_TOKEN=
