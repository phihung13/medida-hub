# syntax=docker/dockerfile:1
# ============================================================================
#  BuildKit cache mounts: pnpm store + Next.js cache sống sót qua --no-cache
#  của Coolify. Lần đầu vẫn full build, từ lần 2 trở đi install + build nhanh
#  vì packages đã có trong store cache và Next.js compile incremental.
# ============================================================================
FROM node:22.20-bookworm-slim
ARG NEXT_PUBLIC_VERSION
ENV NEXT_PUBLIC_VERSION=$NEXT_PUBLIC_VERSION
# ffmpeg: trộn nhạc nền podcast (Phát hiện → Sản xuất)
RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ \
    make \
    python3-pip \
    bash \
    nginx \
    ffmpeg \
&& rm -rf /var/lib/apt/lists/*

RUN addgroup --system www \
 && adduser --system --ingroup www --home /www --shell /usr/sbin/nologin www \
 && mkdir -p /www \
 && chown -R www:www /www /var/lib/nginx

RUN npm --no-update-notifier --no-fund --global install pnpm@10.6.1 pm2

WORKDIR /app

# ── TẦNG 1: cài dependency CHỈ từ manifest ─────────────────────────────────
# Copy manifest TRƯỚC code: layer install (13-14 phút) chỉ phụ thuộc lockfile
# → cache-hit qua mọi commit (trước đây nằm sau COPY . nên chạy lại MỖI deploy).
# --ignore-scripts: postinstall (prisma-generate, fetch-gtm) cần source — chưa
# copy — nên hoãn; lần install thứ 2 bên dưới sẽ chạy scripts đầy đủ.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY apps/backend/package.json apps/backend/
COPY apps/commands/package.json apps/commands/
COPY apps/extension/package.json apps/extension/
COPY apps/frontend/package.json apps/frontend/
COPY apps/orchestrator/package.json apps/orchestrator/
COPY apps/sdk/package.json apps/sdk/
RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --ignore-scripts --reporter=silent

# ── TẦNG 2: code + scripts ──────────────────────────────────────────────────
COPY . /app
COPY var/docker/nginx.conf /etc/nginx/nginx.conf

# Install lần 2: node_modules đã có nên rất nhanh — chủ yếu chạy postinstall
# CỦA PROJECT (prisma generate, fetch-gtm) — các script này chạy mỗi lần install.
# --reporter=silent giữ log gọn (log khổng lồ từng làm phình RAM phía Coolify).
#
# NHƯNG script build của DEPENDENCY native (bcrypt → bcrypt_lib.node) KHÔNG chạy
# lại ở lượt 2: lượt 1 đã --ignore-scripts nên bỏ qua node-gyp, lượt 2 thấy
# lockfile khớp + node_modules sẵn có nên coi như xong, không build lại bcrypt.
# Hậu quả: backend crash "Cannot find module .../bcrypt_lib.node". `pnpm rebuild
# bcrypt` ép compile binding (g++/make/python3 đã cài ở tầng apt trên cùng).
RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --reporter=silent \
 && pnpm rebuild bcrypt

# 8GB heap: nest build (tsc) biên dịch cả libraries/nestjs-libraries lớn — 4GB
# tràn heap → build backend chết exit 255 giữa chừng. VPS 62GB nên 8GB an toàn.
RUN --mount=type=cache,id=nextjs-cache,target=/app/apps/frontend/.next/cache \
    NODE_OPTIONS="--max-old-space-size=8192" pnpm run build

CMD ["sh", "-c", "nginx && pnpm run pm2"]
